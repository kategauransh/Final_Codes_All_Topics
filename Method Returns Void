Programs
1) Void method printing “Hello, World!”
class Test {

    void display() {

        System.out.println("Hello, World!");

    }

    public static void main(String[] args) {

        Test t = new Test();

        t.display();

    }
}
Output
Hello, World!
2) Void method accepting name and printing greeting
class Test {

    void greet(String name) {

        System.out.println("Hello " + name);

    }

    public static void main(String[] args) {

        Test t = new Test();

        t.greet("Gauransh");

    }
}
Output
Hello Gauransh
3) Void method printing numbers from 1 to 10
class Test {

    void printNumbers() {

        for(int i=1; i<=10; i++) {

            System.out.println(i);

        }
    }

    public static void main(String[] args) {

        Test t = new Test();

        t.printNumbers();

    }
}
4) Void method printing array elements
class Test {

    void display(int arr[]) {

        for(int i=0; i<arr.length; i++) {

            System.out.println(arr[i]);

        }
    }

    public static void main(String[] args) {

        int a[] = {10,20,30};

        Test t = new Test();

        t.display(a);

    }
}
Output
10
20
30
5) Void method performing calculation without returning result
class Test {

    void add(int a, int b) {

        int sum = a + b;

        System.out.println("Sum = " + sum);

    }

    public static void main(String[] args) {

        Test t = new Test();

        t.add(10,20);

    }
}
Output
Sum = 30
