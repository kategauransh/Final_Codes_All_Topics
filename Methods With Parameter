3) Method accepting array and returning maximum element
class Test {

    int max(int arr[]) {

        int max = arr[0];

        for(int i=1; i<arr.length; i++) {

            if(arr[i] > max) {

                max = arr[i];
            }
        }

        return max;
    }

    public static void main(String[] args) {

        int a[] = {10,50,30,80};

        Test t = new Test();

        System.out.println(t.max(a));

    }
}
Output
80
